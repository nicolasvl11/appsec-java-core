{
  "title": "AppSec Java Core",
  "uid": "appsec-java-core",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m]) * 60",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (4xx/5xx per min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]) * 60",
          "legendFormat": "{{method}} {{uri}} {{status}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rate Limited Requests (429/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=\"429\"}[1m]) * 60",
          "legendFormat": "429 {{uri}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM Heap Used (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{id}}",
          "datasource": "Prometheus"
        }
      ]
    }
  ]
}
