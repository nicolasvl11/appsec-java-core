# Copy to secret.yml, fill in values, and apply with: kubectl apply -f k8s/secret.yml
# NEVER commit the filled-in secret.yml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: appsec-secrets
  namespace: appsec
type: Opaque
stringData:
  DB_URL: "jdbc:postgresql://postgres-service:5432/appsec"
  DB_USER: "appsec"
  DB_PASS: "change-me-in-production"
  REDIS_HOST: "redis-service"
  JWT_PRIVATE_KEY: "base64-encoded-rsa-private-key"
  JWT_PUBLIC_KEY: "base64-encoded-rsa-public-key"
  GOOGLE_CLIENT_ID: "your-google-client-id"
  GOOGLE_CLIENT_SECRET: "your-google-client-secret"
  GITHUB_CLIENT_ID: "your-github-client-id"
  GITHUB_CLIENT_SECRET: "your-github-client-secret"
